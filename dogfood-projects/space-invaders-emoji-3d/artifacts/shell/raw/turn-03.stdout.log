finalPort = typeof address === \"object\" && address ? address.port : port;\n    process.stdout.write(\"Serving Emoji Star Lanes at http://\" + host + \":\" + finalPort + \"\\n\");\n  });\n}\n\nserver.on(\"error\", (error) => {\n  if (error?.code === \"EADDRINUSE\") {\n    process.stderr.write(\"Port \" + preferredPort + \" is busy; falling back to a free port.\\n\");\n    start(0);\n    return;\n  }\n  throw error;\n});\n\nfor (const signal of [\"SIGINT\", \"SIGTERM\"]) {\n  process.on(signal, () => {\n    server.close(() => process.exit(0));\n  });\n}\n\nstart(preferredPort);\n\nnode:http\nnode:path\nnode:url\nnode:fs/promises\nresolveRequestPath\nstart\nroot\npreferredPort\nhost\nMIME_TYPES\npathname\nnormalized\nfilePath\nserver\nbody\naddress\nfinalPort",
