{
  "name": "@dharmax/ai-workflow",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Autonomous Engineering OS and ai-workflow CLI for token-efficient JS/TS repository work.",
  "files": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "MISSION.md",
    "README.md",
    "cli",
    "core",
    "docs",
    "enforcement.md",
    "epics.md",
    "execution-protocol.md",
