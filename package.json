    "project-guidelines.md",
    "runtime",
    "scripts",
    "shared",
    "skills",
    "templates"
  ],
  "bin": {
    "ai-workflow": "./cli/ai-workflow.mjs",
    "ai-workflow-init": "./scripts/init-project.mjs",
    "ai-workflow-kanban": "./runtime/scripts/ai-workflow/kanban.mjs",
    "ai-workflow-ticket": "./runtime/scripts/ai-workflow/kanban-ticket.mjs",
