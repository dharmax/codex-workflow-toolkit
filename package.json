    "ai-workflow-guideline-audit": "./runtime/scripts/ai-workflow/guideline-audit.mjs",
    "ai-workflow-audit": "./runtime/scripts/ai-workflow/workflow-audit.mjs"
  },
  "scripts": {
    "init:here": "node scripts/init-project.mjs --target .",
    "kanban": "node runtime/scripts/ai-workflow/kanban.mjs",
    "ai-workflow-ticket": "node runtime/scripts/ai-workflow/kanban-ticket.mjs",
    "ai-workflow-guidance": "node runtime/scripts/ai-workflow/guidance-summary.mjs",
    "ai-workflow-verify": "node runtime/scripts/ai-workflow/verification-summary.mjs",
    "ai-workflow-review": "node runtime/scripts/ai-workflow/review-summary.mjs",
    "ai-workflow-audit:guidelines": "node runtime/scripts/ai-workflow/guideline-audit.mjs",
    "ai-workflow-audit": "node runtime/scripts/ai-workflow/workflow-audit.mjs",
    "ticket": "node runtime/scripts/ai-workflow/kanban-ticket.mjs",
    "guidance": "node runtime/scripts/ai-workflow/guidance-summary.mjs",
    "verify": "node runtime/scripts/ai-workflow/verification-summary.mjs",
    "review": "node runtime/scripts/ai-workflow/review-summary.mjs",
    "audit:guidelines": "node runtime/scripts/ai-workflow/guideline-audit.mjs",
    "audit": "node runtime/scripts/ai-workflow/workflow-audit.mjs",
    "ai-workflow": "node cli/ai-workflow.mjs",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
